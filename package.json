  "lint-staged": {
    "*": "prettier --ignore-unknown --write",
    "*.{js,ts,jsx,tsx,cjs,mjs}": [
      "eslint --fix --max-warnings=0 --no-warn-ignored"
    ]
  },
  "browserslist": [
    "last 1 version"
  ],
  "scripts": {
    "predev": "node ./scripts/generate-articles-manifest.mjs",
    "dev": "next dev -p 3939",
    "dev:network": "next dev -H 192.168.1.4 -p 3939",
    "prebuild": "node ./scripts/generate-articles-manifest.mjs",
    "build": "next build --webpack",
    "analyze": "ANALYZE=true next build",
    "start": "next start -p 3939",
    "lint": "eslint .  --concurrency=auto --max-warnings=0",
    "lint:fix": "eslint . --fix --concurrency=auto --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:storybook": "vitest run --config vitest.storybook.config.ts",
    "test:storybook:watch": "vitest watch --config vitest.storybook.config.ts",
    "prettier": "prettier --ignore-unknown --write .",
    "typecheck": "tsc",
    "typecheck:watch": "tsc --watch",
    "clean": "rimraf .next node_modules tsconfig.tsbuildinfo pnpm-lock.yaml",
    "gen": "node ./scripts/generate-blog-templete.mjs",
    "postgen": "node ./scripts/generate-articles-manifest.mjs",
    "gen:manifest": "node ./scripts/generate-articles-manifest.mjs",
    "playwright": "playwright test",
    "playwright:ui": "playwright test --ui",
    "playwright:headed": "playwright test --headed",
    "playwright:debug": "playwright test --debug",
    "playwright:codegen": "exec playwright codegen",
    "storybook": "storybook dev -p 6066",
    "build-storybook": "storybook build"
  },
